    "_postman_id": "675fd13f-bc4a-479d-a291-a2509182d0b0",
    "name": "Materialize HTTP API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Session-less HTTP API for executing SQL statements against a Materialize\nregion. Supports a simple mode (single query string) and an extended mode\n(array of parameterized queries). Session-bound statements such as\nSUBSCRIBE, DECLARE, FETCH, and COPY are not supported over HTTP.\n\n\nContact Support:\n Name: Materialize",
      "type": "text/plain"
